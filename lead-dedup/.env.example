# Adaba Lead Deduplication System — Environment Variables
# Copy this file to .env and fill in your values

# ─────────────────────────────────────────────────────
# PostgreSQL Database (from Render dashboard)
# ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://adaba_ois_user:SgHogYoPN7AHmUXvk2xGC81M84K5tcwR@dpg-d79ubd7kijhs73940cug-a.oregon-postgres.render.com/adaba_ois

# ─────────────────────────────────────────────────────
# Telegram Bot
# ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=7077745263:AAFIoYbGV5z8KZBh9MeqSrawb2gY0UgEa3s

# The chat ID of your Telegram channel/group where reports are sent
# Create a group, add @Adabaorders_bot, and get the group chat ID
TELEGRAM_REPORT_CHANNEL_ID=-1001234567890

# ─────────────────────────────────────────────────────
# Gmail OAuth2 (credentials.json must also be uploaded)
# ─────────────────────────────────────────────────────
# Path to the OAuth2 credentials file from Google Cloud Console
GMAIL_CREDENTIALS_PATH=/etc/secrets/credentials.json

# Path to the token file (auto-generated after first auth)
GMAIL_TOKEN_PATH=/etc/secrets/token.json

# ─────────────────────────────────────────────────────
# Optional Settings
# ─────────────────────────────────────────────────────
# How often to poll Gmail (in seconds). Default: 120 (2 minutes)
POLL_INTERVAL_SECONDS=120

# Gmail label to filter emails (leave empty to check all unread)
# GMAIL_LABEL_FILTER=
